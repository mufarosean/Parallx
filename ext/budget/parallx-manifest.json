{
  "manifestVersion": 1,
  "id": "parallx.budget",
  "name": "Budget",
  "version": "0.1.0",
  "publisher": "parallx",
  "description": "Gmail-sourced budget dashboard. Pulls transaction emails through a local AI pipeline into a per-workspace SQLite ledger.",
  "main": "main.js",
  "activationEvents": ["*"],
  "engines": {
    "parallx": "^0.1.0"
  },
  "capabilities": {
    "fs": { "scope": "workspace-files", "modes": ["read", "write"] }
  },
  "contributes": {
    "viewContainers": [
      {
        "id": "budget-container",
        "title": "Budget",
        "icon": "wallet",
        "location": "sidebar"
      }
    ],
    "views": [
      { "id": "budget.nav", "name": "Budget", "defaultContainerId": "budget-container" }
    ],
    "editors": [
      { "typeId": "budget.editor", "displayName": "Budget" }
    ],
    "commands": [
      { "id": "budget.openDashboard",     "title": "Open Overview",            "category": "Budget" },
      { "id": "budget.openPlan",          "title": "Open Plan",                "category": "Budget" },
      { "id": "budget.openSettings",      "title": "Open Settings",            "category": "Budget" },
      { "id": "budget.openAccounts",      "title": "Open Accounts",            "category": "Budget" },
      { "id": "budget.openTransactions",  "title": "Open Transactions",        "category": "Budget" },
      { "id": "budget.openBudgets",       "title": "Open Budgets",             "category": "Budget" },
      { "id": "budget.openRecurring",     "title": "Open Recurring",           "category": "Budget" },
      { "id": "budget.openCashFlow",      "title": "Open Cash Flow",           "category": "Budget" },
      { "id": "budget.openReports",       "title": "Open Reports",             "category": "Budget" },
      { "id": "budget.openRules",         "title": "Open Rules",               "category": "Budget" },
      { "id": "budget.openReconcile",     "title": "Open Reconcile",           "category": "Budget" },
      { "id": "budget.openCategories",    "title": "Open Categories",          "category": "Budget" },
      { "id": "budget.openReviewQueue",   "title": "Open Review Queue",        "category": "Budget" },
      { "id": "budget.openSyncLog",       "title": "Open Sync Log",            "category": "Budget" },
      { "id": "budget.openImportExport",  "title": "Open Import / Export",     "category": "Budget" },
      { "id": "budget.sync",              "title": "Sync Gmail Transactions",  "category": "Budget" },
      { "id": "budget.reprocessHistory",  "title": "Reprocess History (apply rules to old rows)", "category": "Budget" },
      { "id": "budget.exportCsv",         "title": "Export Transactions to CSV", "category": "Budget" },
      { "id": "budget.importCsv",         "title": "Import Transactions from CSV", "category": "Budget" }
    ],
    "configuration": [
      {
        "title": "Budget",
        "properties": {
          "budget.gmailMcpServerId": {
            "type": "string",
            "default": "gmail",
            "description": "The MCP server ID under which the Gmail server is registered (Settings → MCP Servers → row id). Defaults to 'gmail' to match the bundled catalog entry. If you renamed the row on install, update this to match exactly."
          },
          "budget.gmailQuery": {
            "type": "string",
            "default": "from:(chase.com OR americanexpress.com OR capitalone.com OR discover.com OR citibank.com OR wellsfargo.com OR bankofamerica.com OR usbank.com)",
            "description": "Gmail search filter applied to every sync. Defaults cover major US issuers. Use Gmail search syntax (e.g. add OR clauses for additional banks)."
          },
          "budget.syncStartDays": {
            "type": "number",
            "default": 90,
            "minimum": 1,
            "maximum": 3650,
            "description": "On the very first sync (no cursor yet), import mail received within this many days."
          },
          "budget.preferredModelId": {
            "type": "string",
            "default": "",
            "description": "Model id to use for classification/extraction/categorization. Empty = first model returned by api.lm.getModels()."
          },
          "budget.syncIntervalMinutes": {
            "type": "number",
            "default": 30,
            "minimum": 5,
            "maximum": 1440,
            "description": "How often the scheduled cron job runs `budget.sync`. Disable from the Scheduled Jobs UI to turn off automatic sync."
          }
        }
      }
    ]
  }
}
