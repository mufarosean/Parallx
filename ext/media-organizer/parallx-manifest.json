{
  "manifestVersion": 1,
  "id": "parallx-community.media-organizer",
  "name": "Media Organizer",
  "version": "0.9.0",
  "publisher": "parallx-community",
  "description": "Organize photos and videos with tags, albums, and EXIF metadata.",
  "main": "main.js",
  "activationEvents": ["*"],
  "engines": {
    "parallx": "^0.1.0"
  },
  "contributes": {
    "commands": [
      { "id": "media-organizer.scan", "title": "Scan Directory", "category": "Media Organizer" },
      { "id": "media-organizer.cancelScan", "title": "Cancel Scan", "category": "Media Organizer" },
      { "id": "media-organizer.generateThumbnails", "title": "Generate Thumbnails", "category": "Media Organizer" },
      { "id": "media-organizer.cleanThumbnails", "title": "Clean Orphan Thumbnails", "category": "Media Organizer" },
      { "id": "media-organizer.cacheStats", "title": "Show Thumbnail Cache Stats", "category": "Media Organizer" },
      { "id": "media-organizer.openGrid", "title": "Open Media Grid", "category": "Media Organizer" },
      { "id": "media-organizer.createAlbum", "title": "Create Album", "category": "Media Organizer" },
      { "id": "media-organizer.reviewWebP", "title": "Review Animated WebP Files", "category": "Media Organizer" },
      { "id": "media-organizer.setAutoWebPMode", "title": "Set Auto-WebP Mode (Off / Suggest / Auto)", "category": "Media Organizer" },
      { "id": "media-organizer.rebuildSearchIndex", "title": "Rebuild Search Index", "category": "Media Organizer" },
      { "id": "media-organizer.buildPHashes", "title": "Build Perceptual Hashes (find near-duplicates)", "category": "Media Organizer" },
      { "id": "media-organizer.findDuplicates", "title": "Find Duplicates", "category": "Media Organizer" },
      { "id": "media-organizer.saveSmartAlbum", "title": "Save Current Search as Smart Album", "category": "Media Organizer" },
      { "id": "media-organizer.openSmartAlbum", "title": "Open Smart Album", "category": "Media Organizer" },
      { "id": "media-organizer.stackSelected", "title": "Stack Selected Items", "category": "Media Organizer" },
      { "id": "media-organizer.autoStack", "title": "Auto-Stack by Filename", "category": "Media Organizer" },
      { "id": "media-organizer.moveToTrash", "title": "Move Selected to Trash", "category": "Media Organizer" },
      { "id": "media-organizer.emptyTrash", "title": "Empty Trash", "category": "Media Organizer" },
      { "id": "media-organizer.openTimeline", "title": "Open Timeline View", "category": "Media Organizer" },
      { "id": "media-organizer.openMap", "title": "Open Map View", "category": "Media Organizer" },
      { "id": "media-organizer.revealInMO", "title": "Reveal in Media Organizer", "category": "Media Organizer" }
    ],
    "viewContainers": [
      {
        "id": "media-organizer-container",
        "title": "Media Organizer",
        "icon": "image",
        "location": "sidebar"
      }
    ],
    "views": [
      {
        "id": "mediaOrganizer.browser",
        "name": "Media Library",
        "defaultContainerId": "media-organizer-container"
      }
    ],
    "editors": [
      {
        "typeId": "media-organizer-grid",
        "displayName": "Media Grid"
      }
    ]
  }
}
