{
  "name": "@parallx/gmail-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Parallx Gmail MCP server — read-only Gmail access via STDIO JSON-RPC. Exposes a single tool: list_unread.",
  "license": "MIT",
  "type": "module",
  "main": "bundle/server.mjs",
  "bin": {
    "parallx-gmail-mcp": "bundle/server.mjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=bundle/server.mjs",
    "build:tsc": "tsc -p tsconfig.json",
    "start": "node bundle/server.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('bundle',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
